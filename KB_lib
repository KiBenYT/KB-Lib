		-- [NOVO MÉTODO] Função para criar Dropdowns (Menus de Opções)
		function TabObject:CreateDropdown(dropdownText, optionsList, callback)
			dropdownText = dropdownText or "Dropdown"
			optionsList = optionsList or {}
			callback = callback or function() end

			local IsOpened = false
			local SelectedValue = nil

			-- Container Principal (Ajusta o tamanho automaticamente quando abre)
			local DropdownFrame = Instance.new("Frame")
			DropdownFrame.Name = dropdownText.."_Dropdown"
			DropdownFrame.Size = UDim2.new(1, -10, 0, 32) -- Tamanho fechado padrão
			DropdownFrame.BackgroundColor3 = KBLib.Theme.MainFrame
			DropdownFrame.BorderSizePixel = 0
			DropdownFrame.ClipsDescendants = true -- Esconde as opções quando fechado
			DropdownFrame.Parent = TabPage

			local FrameCorner = Instance.new("UICorner")
			FrameCorner.CornerRadius = UDim.new(0, 4)
			FrameCorner.Parent = DropdownFrame

			local FrameStroke = Instance.new("UIStroke")
			FrameStroke.Color = KBLib.Theme.Border
			FrameStroke.Thickness = 1
			FrameStroke.Transparency = 0.6
			FrameStroke.Parent = DropdownFrame

			-- Botão de Clique da Barra Superior do Dropdown
			local TopBarBtn = Instance.new("TextButton")
			TopBarBtn.Size = UDim2.new(1, 0, 0, 32)
			TopBarBtn.BackgroundTransparency = 1
			TopBarBtn.Text = ""
			TopBarBtn.Parent = DropdownFrame

			-- Texto mostrando o Nome ou a Opção Selecionada
			local TitleLabel = Instance.new("TextLabel")
			TitleLabel.Size = UDim2.new(1, -40, 1, 0)
			TitleLabel.Position = UDim2.new(0, 10, 0, 0)
			TitleLabel.BackgroundTransparency = 1
			TitleLabel.Text = dropdownText .. ": ..."
			TitleLabel.TextColor3 = KBLib.Theme.White
			TitleLabel.Font = Enum.Font.Nunito
			TitleLabel.TextSize = 14
			TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
			TitleLabel.Parent = TopBarBtn

			-- Indicador Visual (Seta ou Símbolo de abrir/fechar)
			local Indicator = Instance.new("TextLabel")
			Indicator.Size = UDim2.new(0, 30, 0, 32)
			Indicator.Position = UDim2.new(1, -30, 0, 0)
			Indicator.BackgroundTransparency = 1
			Indicator.Text = "▼"
			Indicator.TextColor3 = KBLib.Theme.Muted
			Indicator.Font = Enum.Font.Nunito
			Indicator.TextSize = 12
			Indicator.Parent = TopBarBtn

			-- Container que vai segurar a lista de botões das opções
			local OptionsContainer = Instance.new("Frame")
			OptionsContainer.Name = "OptionsContainer"
			OptionsContainer.Size = UDim2.new(1, 0, 1, -32)
			OptionsContainer.Position = UDim2.new(0, 0, 0, 32)
			OptionsContainer.BackgroundTransparency = 1
			OptionsContainer.Parent = DropdownFrame

			local OptionsLayout = Instance.new("UIListLayout")
			OptionsLayout.SortOrder = Enum.SortOrder.LayoutOrder
			OptionsLayout.Padding = UDim.new(0, 2)
			OptionsLayout.Parent = OptionsContainer

			-- Função interna para atualizar o tamanho do frame principal do dropdown
			local function toggleDropdown()
				IsOpened = not IsOpened
				if IsOpened then
					Indicator.Text = "▲"
					-- Calcula o tamanho total somando a barra do topo + altura de todas as opções
					local totalOptionsHeight = #optionsList * 26
					DropdownFrame.Size = UDim2.new(1, -10, 0, 32 + totalOptionsHeight + 4)
				else
					Indicator.Text = "▼"
					DropdownFrame.Size = UDim2.new(1, -10, 0, 32)
				end
				-- Atualiza o Canvas da página do Roblox para ajustar o Scroll automaticamente
				if TabPage:IsA("ScrollingFrame") then
					TabPage.CanvasSize = UDim2.new(0, 0, 0, TabPage.UIListLayout.AbsoluteContentSize.Y + 20)
				end
			end

			TopBarBtn.MouseButton1Click:Connect(toggleDropdown)

			-- Criando os botões de cada opção da lista
			for index, optionName in ipairs(optionsList) do
				local OptionBtn = Instance.new("TextButton")
				OptionBtn.Name = optionName.."_Option"
				OptionBtn.Size = UDim2.new(1, -8, 0, 24)
				OptionBtn.Position = UDim2.new(0, 4, 0, 0)
				OptionBtn.BackgroundColor3 = KBLib.Theme.Background -- Cor de fundo contrastando levemente
				OptionBtn.BorderSizePixel = 0
				OptionBtn.Text = tostring(optionName)
				OptionBtn.TextColor3 = KBLib.Theme.Muted
				OptionBtn.Font = Enum.Font.Nunito
				OptionBtn.TextSize = 13
				OptionBtn.AutoButtonColor = false
				OptionBtn.LayoutOrder = index
				OptionBtn.Parent = OptionsContainer

				local OptionCorner = Instance.new("UICorner")
				OptionCorner.CornerRadius = UDim.new(0, 3)
				OptionCorner.Parent = OptionBtn

				-- Efeitos de Hover (Passar o mouse)
				OptionBtn.MouseEnter:Connect(function() OptionBtn.TextColor3 = KBLib.Theme.White end)
				OptionBtn.MouseLeave:Connect(function() OptionBtn.TextColor3 = KBLib.Theme.Muted end)

				-- Evento ao selecionar a opção
				OptionBtn.MouseButton1Click:Connect(function()
					SelectedValue = optionName
					TitleLabel.Text = dropdownText .. ": " .. tostring(optionName)
					toggleDropdown() -- Fecha o menu após escolher
					pcall(callback, optionName)
				end)
			end

			-- Retorna um objeto para controle via script externo
			local DropdownObject = {}

			-- Seleciona uma opção específica via script
			function DropdownObject:Set(value)
				SelectedValue = value
				TitleLabel.Text = dropdownText .. ": " .. tostring(value)
				pcall(callback, value)
			end

			-- NOVO ELEMENTO: Atualiza a lista de opções (Perfeito para o loop de Players do KTG)
			function DropdownObject:Refresh(newList)
				optionsList = newList or {} -- Atualiza a lista interna de opções

				-- 1. Limpa os botões antigos das opções
				for _, child in pairs(OptionsContainer:GetChildren()) do
					if child:IsA("TextButton") then
						child:Destroy()
					end
				end

				-- 2. Cria os novos botões com os nicks atualizados
				for index, optionName in ipairs(optionsList) do
					local OptionBtn = Instance.new("TextButton")
					OptionBtn.Name = optionName.."_Option"
					OptionBtn.Size = UDim2.new(1, -8, 0, 24)
					OptionBtn.Position = UDim2.new(0, 4, 0, 0)
					OptionBtn.BackgroundColor3 = KBLib.Theme.Background
					OptionBtn.BorderSizePixel = 0
					OptionBtn.Text = tostring(optionName)
					OptionBtn.TextColor3 = KBLib.Theme.Muted
					OptionBtn.Font = Enum.Font.Nunito
					OptionBtn.TextSize = 13
					OptionBtn.AutoButtonColor = false
					OptionBtn.LayoutOrder = index
					OptionBtn.Parent = OptionsContainer

					local OptionCorner = Instance.new("UICorner")
					OptionCorner.CornerRadius = UDim.new(0, 3)
					OptionCorner.Parent = OptionBtn

					-- Efeitos de Hover
					OptionBtn.MouseEnter:Connect(function() OptionBtn.TextColor3 = KBLib.Theme.White end)
					OptionBtn.MouseLeave:Connect(function() OptionBtn.TextColor3 = KBLib.Theme.Muted end)

					-- Evento ao selecionar a nova opção
					OptionBtn.MouseButton1Click:Connect(function()
						SelectedValue = optionName
						TitleLabel.Text = dropdownText .. ": " .. tostring(optionName)
						if IsOpened then
							-- Chama a função toggleDropdown original para fechar o menu
							IsOpened = false
							Indicator.Text = "▼"
							DropdownFrame.Size = UDim2.new(1, -10, 0, 32)
						end
						pcall(callback, optionName)
					end)
				end

				-- 3. Se o menu estiver aberto na hora do update, reajusta o tamanho dele na tela
				if IsOpened then
					local totalOptionsHeight = #optionsList * 26
					DropdownFrame.Size = UDim2.new(1, -10, 0, 32 + totalOptionsHeight + 4)
				end
			end

			return DropdownObject
		end
		
