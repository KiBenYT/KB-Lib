			ClickBtn.BackgroundTransparency = 1
			ClickBtn.Text = ""
			ClickBtn.Parent = ToggleFrame

			-- Função visual de atualização do tema Monocromático
			local function updateVisual()
				if ToggleState then
					Box.BackgroundColor3 = KBLib.Theme.White
					BoxStroke.Color = KBLib.Theme.White
				else
					Box.BackgroundColor3 = KBLib.Theme.Background
					BoxStroke.Color = KBLib.Theme.Border
				end
			end
			updateVisual() -- Roda uma vez para aplicar o padrão (default)

			-- Evento de Clique
			ClickBtn.MouseButton1Click:Connect(function()
				ToggleState = not ToggleState
				updateVisual()
				pcall(callback, ToggleState)
			end)

			-- Retorna um objeto para caso você queira alterar o estado via script depois
			local ToggleObject = {}
			function ToggleObject:Set(state)
				ToggleState = state
				updateVisual()
				pcall(callback, ToggleState)
			end
			return ToggleObject
		end 
		
