-- Sistema de Notificações
function KBLib:Notify(titleText, contentText, duration)
	titleText = titleText or "Notificação"
	contentText = contentText or "Conteúdo de notificação"
	duration = duration or 4

	local ScreenGui = PlayerGui:FindFirstChild("KBLib_Gui") or PlayerGui:FindFirstChild("KBLib_NotificationsGui")
	if not ScreenGui then
		ScreenGui = Instance.new("ScreenGui")
		ScreenGui.Name = "KBLib_NotificationsGui"
		ScreenGui.ResetOnSpawn = false
		ScreenGui.Parent = PlayerGui
	end

	local NotifyHolder = ScreenGui:FindFirstChild("NotifyHolder")
	if not NotifyHolder then
		NotifyHolder = Instance.new("Frame")
		NotifyHolder.Name = "NotifyHolder"
		NotifyHolder.Size = UDim2.new(0, 250, 1, -40)
		NotifyHolder.Position = UDim2.new(1, -260, 0, 20)
		NotifyHolder.BackgroundTransparency = 1
		NotifyHolder.Parent = ScreenGui

		local ListLayout = Instance.new("UIListLayout")
		ListLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
		ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
		ListLayout.Padding = UDim.new(0, 8)
		ListLayout.Parent = NotifyHolder
	end

	-- Estrutura da Notificação
	local NotifyFrame = Instance.new("Frame")
	NotifyFrame.Name = "Notification"
	NotifyFrame.Size = UDim2.new(1, 0, 0, 65)
	NotifyFrame.Position = UDim2.new(1, 50, 0, 0)
	NotifyFrame.BackgroundColor3 = KBLib.Theme.MainFrame
	NotifyFrame.BackgroundTransparency = 1
	NotifyFrame.BorderSizePixel = 0
	NotifyFrame.Parent = NotifyHolder

	local Corner = Instance.new("UICorner", NotifyFrame)
	Corner.CornerRadius = UDim.new(0, 5)

	local Stroke = Instance.new("UIStroke", NotifyFrame)
	Stroke.Color = KBLib.Theme.Border
	Stroke.Thickness = 1
	Stroke.Transparency = 1

	local Title = Instance.new("TextLabel")
	Title.Size = UDim2.new(1, -16, 0, 22)
	Title.Position = UDim2.new(0, 8, 0, 4)
	Title.BackgroundTransparency = 1
	Title.Text = titleText
	Title.TextColor3 = KBLib.Theme.White
	Title.Font = Enum.Font.Nunito
	Title.TextSize = 14
	Title.TextXAlignment = Enum.TextXAlignment.Left
	Title.TextTransparency = 1
	Title.Parent = NotifyFrame

	local Content = Instance.new("TextLabel")
	Content.Size = UDim2.new(1, -16, 1, -30)
	Content.Position = UDim2.new(0, 8, 0, 24)
	Content.BackgroundTransparency = 1
	Content.Text = contentText
	Content.TextColor3 = KBLib.Theme.Muted
	Content.Font = Enum.Font.Nunito
	Content.TextSize = 13
	Content.TextWrapped = true
	Content.TextXAlignment = Enum.TextXAlignment.Left
	Content.TextYAlignment = Enum.TextYAlignment.Top
	Content.TextTransparency = 1
	Content.Parent = NotifyFrame

	-- Tweens
	local tweenInfoIn = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	local tweenInFrame = TweenService:Create(NotifyFrame, tweenInfoIn, {Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0})
	local tweenInStroke = TweenService:Create(Stroke, tweenInfoIn, {Transparency = 0})
	local tweenInTitle = TweenService:Create(Title, tweenInfoIn, {TextTransparency = 0})
	local tweenInContent = TweenService:Create(Content, tweenInfoIn, {TextTransparency = 0})

	tweenInFrame:Play()
	tweenInStroke:Play()
	tweenInTitle:Play()
	tweenInContent:Play()

	-- Deleta automaticamente com efeito de Fade Out
	task.delay(duration, function()
		local tweenInfoOut = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		local tweenOutFrame = TweenService:Create(NotifyFrame, tweenInfoOut, {BackgroundTransparency = 1})
		local tweenOutStroke = TweenService:Create(Stroke, tweenInfoOut, {Transparency = 1})
		local tweenOutTitle = TweenService:Create(Title, tweenInfoOut, {TextTransparency = 1})
		local tweenOutContent = TweenService:Create(Content, tweenInfoOut, {TextTransparency = 1})

		tweenOutFrame:Play()
		tweenOutStroke:Play()
		tweenOutTitle:Play()
		tweenOutContent:Play()

		tweenOutFrame.Completed:Connect(function()
			NotifyFrame:Destroy()
		end)
	end)
end

